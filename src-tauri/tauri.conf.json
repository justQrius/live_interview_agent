{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Live Interview Agent",
  "version": "0.1.0",
  "identifier": "com.liveinterviewagent.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Live Interview Agent",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' 'wasm-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' ws: localhost:* asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sidecar-server"
    ],
    "resources": [],
    "licenseFile": "../LICENSE",
    "license": "MIT",
    "copyright": "Copyright 2026 Live Interview Agent",
    "category": "Utility",
    "shortDescription": "Real-time AI copilot for live conversations",
    "longDescription": "Live Interview Agent is a cross-platform desktop copilot for live conversations — job interviews, sales calls, customer meetings, and 1:1s. It captures the other side of the call via system audio, transcribes in real time, and drafts grounded answers drawn from your own documents (resume, JD, notes, playbooks). All processing can stay on-device with local Whisper STT; API keys are stored in the OS keychain.",
    "publisher": "Live Interview Agent",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "5f8a9c2b-3d4e-4a1f-b8c6-7e9d0f1a2b3c"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        }
      },
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libssl3",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "openssl",
          "gtk3"
        ]
      }
    }
  }
}
