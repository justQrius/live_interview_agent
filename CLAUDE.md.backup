│       ├── audio/          # Capture, VAD, diarization
│       ├── stt/            # Gemini STT client
│       ├── context/        # Document parsing/chunking
│       ├── rag/            # ChromaDB + retrieval
│       └── llm/            # Gemini LLM client
└── _prism/                # SDLC artifacts
