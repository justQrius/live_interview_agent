{
  "$schema": "https://opencode.ai/config.json",
  // Prism SDLC Plugin for OpenCode
  // Copy this folder to your project root
  // Context files (inside .opencode/)
  "instructions": [
    ".opencode/PRISM.md"
  ],
  // Default agent when OpenCode starts
  "default_agent": "orchestrator",
  // Agent configuration with models
  "agent": {
    // Primary agent - session orchestrator
    "orchestrator": {
      "description": "Master session coordinator for Prism SDLC development"
    },
    // Planning agents
    "pm": {
      "description": "Product Manager - requirements and PRD creation"
    },
    "architect": {
      "description": "System Architect - architecture and design"
    },
    // Implementation agents
    "developer": {
      "description": "Developer - TDD implementation"
    },
    "reviewer": {
      "description": "Code Reviewer - quality and security review"
    },
    // Support agents (smaller/faster models)
    "explorer": {
      "description": "Codebase Explorer - analysis and tracing"
    },
    "tester": {
      "description": "Tester - verification and test coverage"
    },
    "documenter": {
      "description": "Documenter - documentation generation"
    }
  },
  // MCP Servers (optional)
  "mcp": {
    // Add your MCP servers here
    // "context7": {
    //   "type": "remote",
    //   "url": "https://mcp.context7.com/mcp"
    // }
  }
}